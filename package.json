{
  "name": "luma-peek",
  "version": "0.1.0",
  "description": "A fast, pluggable image viewer for the web",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite playground",
    "build": "tsdown",
    "test": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "image-viewer",
    "lightbox",
    "gallery"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blackonionqeq/luma-peek.git"
  },
  "sideEffects": false
}
